vjust = -1,
family = FONT_FAMILY,
size = (AXIS_SIZE - 3.5) / .pt,
color = "grey25",
fill = "#B9B4AC",
label.size = NA,
label.padding = unit(0.25, "lines"),
lineheight = 0.95
) +
# Country labels at right
geom_label_repel_tpa(
data = labels_008,
mapping = aes(label = Country),
nudge_x = 2,
hjust = 0,
with_segment = TRUE
) +
scale_x_continuous(
breaks = seq(2010, 2050, 5),
expand = expansion(mult = c(0.01, 0.18))
) +
scale_y_continuous(
labels = label_comma(),
expand = expansion(mult = c(0.02, 0.05))
) +
scale_color_tpa() +
# Make legend clearly distinguish observed vs projected
scale_linetype_manual(
name = NULL,
values = c(
"Observed" = "solid",
"Projected" = "22"
),
breaks = c("Observed", "Projected")
) +
guides(
color = "none",
linetype = guide_legend(
override.aes = list(
color = "#B9B4AC",
linewidth = 1.1
)
)
) +
labs(
title    = meta$title,
subtitle = meta$subtitle,
caption  = meta$caption,
y        = "STEM PhDs per year"
) +
theme_tpa() +
theme(
legend.position = "top",
legend.direction = "horizontal"
)
save_chart(fig_008, "fig_008")
meta <- get_meta("fig_008")
df_008 <- read_fig("fig_008") %>%
mutate(across(-Year, as.numeric)) %>%
pivot_longer(-Year, names_to = "series", values_to = "value") %>%
filter(!is.na(value)) %>%
mutate(
period  = if_else(
str_detect(series, "\\(projected\\)"),
"Projected",
"Observed"
),
Country = str_remove(series, " \\(projected\\)") %>%
str_trim()
) %>%
select(Year, Country, period, value)
country_order <- df_008 %>%
filter(Year == max(Year)) %>%
arrange(desc(value)) %>%
pull(Country)
df_008 <- df_008 %>%
mutate(Country = factor(Country, levels = country_order))
labels_008 <- df_008 %>%
group_by(Country) %>%
slice_max(Year, n = 1) %>%
ungroup()
proj_start <- df_008 %>%
filter(period == "Projected") %>%
pull(Year) %>%
min()
x_max <- max(df_008$Year)
y_max <- max(df_008$value)
# Milestone annotations
milestones <- tribble(
~year, ~label,
2019, "China Tops US in STEM PhDs",
2033, "India Tops US in STEM PhDs",
2042, "India Tops China in STEM PhDs, Both now produce 1.5x US",
2050, "India Doubles US STEM Production"
)
# Gap ranges for milestone labels
milestones_plot <- milestones %>%
mutate(
label_ymin = case_when(
year == 2042 ~ y_max * 0.30,
TRUE ~ y_max * 0.58
),
label_ymax = y_max * 1.02
)
fig_008 <- ggplot(
df_008,
aes(
Year,
value,
color = Country,
group = Country
)
) +
# Shaded projected region
annotate(
"rect",
xmin = proj_start - 0.5,
xmax = x_max + 0.5,
ymin = -Inf,
ymax = Inf,
fill = "grey92",
alpha = 0.5
) +
# Projected label
annotate(
"text",
x = proj_start,
y = y_max * 0.98,
label = "Projected",
hjust = 0,
vjust = 0,
family = FONT_FAMILY,
size = AXIS_SIZE / .pt,
color = "grey45",
fontface = "italic"
) +
# Milestone vertical lines BELOW label gap
geom_segment(
data = milestones_plot,
aes(
x = year,
xend = year,
y = 0,
yend = label_ymin
),
inherit.aes = FALSE,
linetype = "dotted",
color = "grey92",
linewidth = 0.8
) +
# Milestone vertical lines ABOVE label gap
geom_segment(
data = milestones_plot,
aes(
x = year,
xend = year,
y = label_ymax,
yend = y_max * 1.05
),
inherit.aes = FALSE,
linetype = "dotted",
color = "grey92",
linewidth = 0.8
) +
# Observed lines
geom_line(
data = filter(df_008, period == "Observed"),
aes(linetype = period),
linewidth = 0.9
) +
# Projected lines
geom_line(
data = filter(df_008, period == "Projected"),
aes(linetype = period),
linewidth = 0.9
) +
# Milestone labels drawn LAST so they mask lines underneath
geom_label(
data = milestones_plot,
aes(
x = year,
y = y_max * 1,
label = label
),
inherit.aes = FALSE,
angle = 90,
hjust = .99,
vjust = -1,
family = FONT_FAMILY,
size = (AXIS_SIZE - 3.5) / .pt,
color = "grey25",
fill = "grey92",
label.size = NA,
label.padding = unit(0.75, "lines"),
lineheight = 0.95
) +
# Country labels at right
geom_label_repel_tpa(
data = labels_008,
mapping = aes(label = Country),
nudge_x = 2,
hjust = 0,
with_segment = TRUE
) +
scale_x_continuous(
breaks = seq(2010, 2050, 5),
expand = expansion(mult = c(0.01, 0.18))
) +
scale_y_continuous(
labels = label_comma(),
expand = expansion(mult = c(0.02, 0.05))
) +
scale_color_tpa() +
# Make legend clearly distinguish observed vs projected
scale_linetype_manual(
name = NULL,
values = c(
"Observed" = "solid",
"Projected" = "22"
),
breaks = c("Observed", "Projected")
) +
guides(
color = "none",
linetype = guide_legend(
override.aes = list(
color = "grey92",
linewidth = 2
)
)
) +
labs(
title    = meta$title,
subtitle = meta$subtitle,
caption  = meta$caption,
y        = "STEM PhDs per year"
) +
theme_tpa() +
theme(
legend.position = "top",
legend.direction = "horizontal"
)
save_chart(fig_008, "fig_008")
