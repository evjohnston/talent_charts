source("R/chart_layers.R")
source("R/maps.R")
eta <- get_meta("fig_015")
df_015 <- read_fig("fig_015") %>%
rename(Year = 1,
`U.S. citizens and permanent residents` = 2,
`Temporary visa holders` = 3) %>%
mutate(across(everything(), as.numeric)) %>%
pivot_longer(-Year, names_to = "Status", values_to = "Count") %>%
order_by_total(Status, Count)
fig_015 <- ggplot(df_015, aes(Year, Count, fill = Status)) +
geom_area(alpha = 0.95) +
scale_x_years(df_015$Year) +
scale_y_continuous(labels = label_comma(),
expand = expansion(mult = c(0, 0.05))) +
scale_fill_manual(values = c(
"U.S. citizens and permanent residents" = tpa_colors[1],
"Temporary visa holders"                = tpa_colors[4]
)) +
labs_meta(meta, y = "Graduate students enrolled") +
theme_tpa()
save_chart(fig_015, "fig_015")
